# ──────────────────────────────────────────────────────────────────────────────
# Ayursutra Backend — Environment Variables
# Copy this file to .env for local development
# On Railway: paste each KEY=VALUE into the Variables panel (do NOT upload .env)
# ──────────────────────────────────────────────────────────────────────────────

# Server (Railway sets PORT automatically — only set for local dev)
PORT=5000
NODE_ENV=production

# MongoDB Atlas (SRV connection string — copy from Atlas → Connect → Drivers)
MONGO_URI=mongodb+srv://YOUR_ATLAS_USER:YOUR_ATLAS_PASSWORD@YOUR_CLUSTER.mongodb.net/ayursutra?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRE=7d

# Frontend URL (your Vercel deployment URL — no trailing slash)
FRONTEND_URL=https://ayursutra-neon.vercel.app

# ── Email (Gmail App Password) ─────────────────────────────────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Generate a 16-character password and paste it below
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password