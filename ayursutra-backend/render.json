{
  "name": "Ayursutra Backend",
  "description": "Healthcare appointment scheduling platform - Backend API",
  "repository": "https://github.com/OZAHET22/Ayursutra",
  "keywords": ["healthcare", "appointments", "nodejs", "express", "mongodb"],
  "buildCommand": "npm install",
  "startCommand": "node server.js",
  "env": {
    "PORT": {
      "description": "Server port",
      "value": "5000"
    },
    "NODE_ENV": {
      "description": "Environment",
      "value": "production"
    },
    "MONGO_URI": {
      "description": "MongoDB Atlas connection string",
      "required": true
    },
    "JWT_SECRET": {
      "description": "JWT secret key for token generation",
      "required": true
    },
    "EMAIL_USER": {
      "description": "Gmail address for sending emails",
      "required": true
    },
    "EMAIL_PASSWORD": {
      "description": "Gmail app-specific password",
      "required": true
    },
    "FRONTEND_URL": {
      "description": "Frontend deployment URL",
      "value": "https://ayursutra-awalh28ov-ozahet22s-projects.vercel.app"
    },
    "FIREBASE_PROJECT_ID": {
      "description": "Firebase project ID",
      "required": true
    },
    "FIREBASE_PRIVATE_KEY": {
      "description": "Firebase private key (multiline)",
      "required": true
    },
    "FIREBASE_CLIENT_EMAIL": {
      "description": "Firebase client email",
      "required": true
    }
  }
}
